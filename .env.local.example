# Internal engine paths (defaults — engines/mlb_engine/*)
BASEBALL_PREDICTOR_PATH=engines/mlb_engine/predictor
BASEBALL_PROPS_PATH=engines/mlb_engine/props

# THE_ODDS_API_KEY lives in engines/mlb_engine/predictor/.env and engines/mlb_engine/props/.env
# (loaded by export_daily_picks.py via load_predictor_env / load_props_env).

# Optional: props subprocess timeout in seconds (default 1800). Live props often need 15–20 min.
# PROPS_EXPORT_TIMEOUT_SECONDS=1800
